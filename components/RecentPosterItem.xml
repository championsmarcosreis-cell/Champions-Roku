      width="160"
      height="3"
      color="0xD8B765FF"
      visible="false"
    />
    <Rectangle
      id="borderLeft"
      translation="[0, 0]"
      width="3"
      height="240"
      color="0xD8B765FF"
      visible="false"
    />
    <Rectangle
      id="borderRight"
      translation="[157, 0]"
      width="3"
      height="240"
      color="0xD8B765FF"
      visible="false"
